# External Access Configuration - Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# ============================================================================
# REQUIRED for External Access (Route53 + HAProxy + Let's Encrypt)
# ============================================================================

# Host's external/public IP address (where HAProxy will listen)
# This is the IP that DNS records will point to
EXTERNAL_IP="203.0.113.10"

# AWS credentials for Route53 DNS management
# Get these from AWS IAM: https://console.aws.amazon.com/iam/
# Required permissions: route53:ListHostedZones, route53:ChangeResourceRecordSets, route53:GetChange
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# Email address for Let's Encrypt certificate notifications
# You'll receive renewal reminders and important updates here
EMAIL="admin@example.com"

# Path to cluster kubeconfig (optional - auto-detected if not set)
# Default: ~/generated_assets/${CLUSTER_NAME}/auth/kubeconfig
#KUBECONFIG="${HOME}/generated_assets/sno-4-20/auth/kubeconfig"

# ============================================================================
# OPTIONAL Configuration
# ============================================================================

# Use Let's Encrypt staging environment (for testing)
# Set to "true" to avoid rate limits while testing
# Default: false (production certificates)
#CERT_STAGING="true"

# AWS Route53 hosted zone ID (optional - auto-detected from base_domain)
# Only needed if auto-detection fails or you have multiple zones
#ROUTE53_HOSTED_ZONE_ID="Z1234567890ABC"

# ============================================================================
# CLUSTER CONFIGURATION (usually set by scripts, not in .env)
# ============================================================================

# Where cluster configurations are stored
# Default: examples (use site-config for gitignored configs)
#SITE_CONFIG_DIR="examples"

# Where generated ISOs and manifests are stored
# Default: ~/generated_assets
#GENERATED_ASSET_PATH="${HOME}/generated_assets"

# Cluster name override (usually auto-detected from cluster.yml)
#CLUSTER_NAME="sno-4-20"

# ============================================================================
# USAGE EXAMPLES
# ============================================================================

# After filling in your values, source this file before running scripts:
#   source .env
#   ./hack/configure-external-access.sh examples/sno-4.20-standard/cluster.yml

# Or the orchestration script will auto-source .env if it exists:
#   ./hack/configure-external-access.sh examples/sno-4.20-standard/cluster.yml

# Individual component scripts:
#   source .env
#   ./hack/configure-haproxy-forwarder.sh examples/sno-4.20-standard/cluster.yml
#   ./hack/configure-route53-dns.sh add examples/sno-4.20-standard/cluster.yml
#   ./hack/configure-letsencrypt-certs.sh

# ============================================================================
# SECURITY NOTES
# ============================================================================

# - NEVER commit .env to git (it contains secrets!)
# - .env is in .gitignore to prevent accidental commits
# - Restrict file permissions: chmod 600 .env
# - Use IAM user with minimal permissions (Route53 only)
# - Consider using AWS IAM roles instead of access keys for EC2 instances
# - Rotate credentials regularly
# - Use AWS Secrets Manager or similar for production deployments
